# vss-recall-bridge environment (build-spec §3.1). Copy to .env and fill in.

# Base URL for the VSS pipeline-manager /manager/* API.
# Direct on the shared network: http://pipeline-manager:3000
# Or via nginx:                 http://nginx:80/manager
VSS_BASE_URL=http://pipeline-manager:3000

# Path to the camera config.
CAMERAS_CONFIG=configs/cameras.yaml

# Scratch dir for segmenting/remux (ephemeral).
CLIPS_DIR=./clips

# Static API key required on every /api/v1/lp/recall/* request. REQUIRED.
BRIDGE_API_KEY=change-me

# Stateful search polling.
SEARCH_POLL_SECONDS=1.0
SEARCH_POLL_TIMEOUT_SECONDS=30

# Default RTSP segment length when a camera omits segment_seconds.
DEFAULT_SEGMENT_SECONDS=60

# Pad applied to the query window (set to one chunk length, e.g. 60).
WINDOW_PAD_SECONDS=0

# Timezone used to resolve NL time windows in queries.
SEARCH_TIMEZONE=UTC

# httpx timeout to VSS.
HTTP_TIMEOUT_SECONDS=30
