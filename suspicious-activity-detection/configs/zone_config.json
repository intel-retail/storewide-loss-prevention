{
  "_comment": "Single source of truth for all app-specific configuration. init.sh reads this to generate docker/.env",

  "scene_name": "storewide loss prevention",
  "scene_zip": "storewide-loss-prevention.zip",

  "cameras": [
    { "name": "lp-camera1", "video": "lp-camera1.mp4" }
  ],

  "models": "person-detection-retail-0013,person-reidentification-retail-0277",
  "model_precision": "FP32",

  "scenescape": {
    "registry": "",
    "version": "v2026.0.0",
    "controller_image": "intel/scenescape-controller",
    "manager_image": "intel/scenescape-manager",
    "dlstreamer_version": "2026.1.0-20260331-weekly-ubuntu24",
    "api_user": "admin"
  },

  "store": {
    "name": "Retail",
    "id": "store_001"
  },

  "services": {
    "lp_service_port": 8082,
    "log_level": "INFO",
    "seaweedfs_s3_port": 8333,
    "seaweedfs_master_port": 9333,
    "seaweedfs_volume_port": 8080
  },

  "scenescape_api": {
    "base_url": "https://web.scenescape.intel.com",
    "auth_path": "/api/v1/auth",
    "scenes_path": "/api/v1/scenes",
    "regions_path": "/api/v1/regions",
    "verify_ssl": false
  },

  "zones": {
    "aisle1": "HIGH_VALUE",
    "aisle2": "CHECKOUT"
  }
}
