<mxfile host="app.diagrams.net" agent="GitHub Copilot" version="24.0.0">
  <diagram id="vlm-recall-hld" name="VLM-Recall HLD">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="VLM-Recall Search with VSS — High-Level Design" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1">
          <mxGeometry x="340" y="20" width="720" height="34" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="&quot;Show me the person in a blue shirt between 2:00–3:00 PM near aisle 7&quot;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="340" y="52" width="720" height="22" as="geometry" />
        </mxCell>

        <!-- ============ LEFT: SOURCES ============ -->
        <mxCell id="cams" value="Store Cameras&#10;&#10;RTSP streams&#10;(aisle-7-cam, entrance, …)&#10;running since yesterday" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#4285F4;fontSize=13;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="190" height="120" as="geometry" />
        </mxCell>

        <mxCell id="user" value="Investigator&#10;+&#10;SWLP Dashboard&#10;(ui/ui_gradio.py)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE8E6;strokeColor=#EA4335;fontSize=13;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="190" height="120" as="geometry" />
        </mxCell>

        <!-- ============ CENTER: THE BRIDGE SERVICE (one system) ============ -->
        <mxCell id="bridge" value="vss-recall-bridge   (the one new service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F4EA;strokeColor=#34A853;verticalAlign=top;fontStyle=1;fontSize=14;fontColor=#1E6B3A;arcSize=3;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="360" y="150" width="430" height="500" as="geometry" />
        </mxCell>

        <!-- Ingest plane (inside bridge) -->
        <mxCell id="ingest" value="Ingest plane  (continuous)&#10;&#10;• segment RTSP → short MP4 clips&#10;• tag each clip from cameras.yaml&#10;  [camera, area_label, store_id, date_bucket]&#10;• upload to VSS + trigger embeddings&#10;• record true capture_start / capture_end" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#34A853;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="385" y="200" width="380" height="160" as="geometry" />
        </mxCell>

        <!-- Query plane (inside bridge) -->
        <mxCell id="query" value="Query plane  (on demand)&#10;&#10;POST /api/v1/lp/recall/search&#10;{ query, cameras, time_start, time_end }&#10;&#10;① capture-time pre-filter (mapping DB)&#10;② appearance search → VSS (timeFilter: null)&#10;③ keep hits in window, enrich, sort&#10;   real_time = capture_start + segment_start" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#34A853;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="385" y="380" width="380" height="180" as="geometry" />
        </mxCell>

        <!-- Mapping DB (owned by bridge) -->
        <mxCell id="mapdb" value="Mapping DB — dedicated 'recall_bridge' DB on VSS postgres-service&#10;(separate database, NOT VSS's app DB · NO video bytes)&#10;videoId → camera, capture_start/end, tags, clip_url" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#E6F4EA;strokeColor=#34A853;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="570" width="310" height="70" as="geometry" />
        </mxCell>

        <!-- ============ RIGHT: STOCK VSS STACK ============ -->
        <mxCell id="vss" value="Stock VSS Search Stack   (unchanged)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF7E0;strokeColor=#F9AB00;verticalAlign=top;fontStyle=1;fontSize=14;fontColor=#9A6700;arcSize=3;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="150" width="430" height="500" as="geometry" />
        </mxCell>

        <mxCell id="pm" value="pipeline-manager — /manager/* API&#10;upload · embed · search  (nginx :12345)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9AB00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="925" y="205" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dataprep" value="vdms-dataprep — sample frames → embeddings&#10;multimodal-embedding-serving (CLIP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9AB00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="925" y="295" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="searchms" value="search-ms — query embed + VDMS similarity&#10;→ segments (segment_start/end, score)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9AB00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="925" y="385" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="vdms" value="VDMS vector DB&#10;frame vectors + metadata (created_at = UPLOAD time)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#FFFFFF;strokeColor=#F9AB00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="480" width="310" height="80" as="geometry" />
        </mxCell>
        <mxCell id="minio" value="minio + postgres (storage / metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F9AB00;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="580" width="310" height="40" as="geometry" />
        </mxCell>

        <!-- ============ EDGES ============ -->
        <!-- ingest flow -->
        <mxCell id="ec1" value="RTSP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4285F4;endArrow=block;fontSize=11;" edge="1" parent="1" source="cams" target="ingest"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec2" value="upload clips + embed&#10;(tags incl. date_bucket)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#F9AB00;endArrow=block;fontSize=10;" edge="1" parent="1" source="ingest" target="pm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec3" value="write capture times" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#34A853;endArrow=block;fontSize=10;" edge="1" parent="1" source="ingest" target="mapdb"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- query flow -->
        <mxCell id="qc1" value="recall query" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA4335;endArrow=block;fontSize=11;" edge="1" parent="1" source="user" target="query"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qc2" value="① read candidates" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#34A853;endArrow=block;fontSize=10;dashed=1;" edge="1" parent="1" source="query" target="mapdb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qc3" value="② appearance + tags search&#10;(timeFilter: null)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#F9AB00;endArrow=block;fontSize=10;" edge="1" parent="1" source="query" target="searchms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qc4" value="enriched results" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#EA4335;endArrow=block;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="query" target="user"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="300" y="700" /></Array></mxGeometry></mxCell>

        <!-- VSS internal -->
        <mxCell id="vc1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#F9AB00;endArrow=block;" edge="1" parent="1" source="pm" target="dataprep"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="vc2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#F9AB00;endArrow=block;" edge="1" parent="1" source="dataprep" target="vdms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="vc3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#F9AB00;endArrow=block;" edge="1" parent="1" source="searchms" target="vdms"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ NOTES ============ -->
        <mxCell id="note1" value="Three axes of the query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;verticalAlign=top;fontStyle=1;fontSize=12;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="640" height="160" as="geometry" />
        </mxCell>
        <mxCell id="note1txt" value="• Appearance &quot;blue shirt&quot;  → VSS embeddings (VDMS similarity)&#10;• Location &quot;aisle 7&quot;       → camera TAG, set once in cameras.yaml&#10;• Real-world time 2–3 PM   → BRIDGE capture_start/end  (NOT VSS timeFilter = upload time)&#10;• In-video position        → segment_start/end;  real_time = capture_start + segment_start&#10;• date_bucket tag scopes VSS to yesterday → avoids top-K dilution on a large index" style="text;html=1;align=left;fontSize=11;spacingLeft=8;fontColor=#333333;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="70" y="708" width="620" height="126" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="Latency (querying yesterday's data)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;verticalAlign=top;fontStyle=1;fontSize=12;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="680" width="610" height="160" as="geometry" />
        </mxCell>
        <mxCell id="note2txt" value="• Heavy work (embed/index) already done at INGEST → query does not re-process video&#10;• Query ≈ mapping lookup (ms) + VSS similarity (~1–4 s) + enrich (ms) ≈ a few seconds&#10;• Independent of stream age; depends on TOTAL index size&#10;• Freshness lag ≈ segment_seconds + embed (~1–1.5 min) → only affects &quot;just now&quot;&#10;• 1 cam @60s = 1,440 clips/day → use date/hour buckets + a retention policy" style="text;html=1;align=left;fontSize=11;spacingLeft=8;fontColor=#333333;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="730" y="708" width="590" height="126" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
