{
  "info": {
    "name": "VLM-Recall / VSS Search",
    "description": "Test requests for the VSS search pipeline used by VLM-Recall. Covers multi-tag and start/end time filtering.\n\nSet the collection variables HOST_IP, VS_HOST_PORT (search-ms, default 7890) and APP_HOST_PORT (Pipeline Manager via nginx, default 12345).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "HOST_IP", "value": "10.223.22.84" },
    { "key": "VS_HOST_PORT", "value": "7890" },
    { "key": "APP_HOST_PORT", "value": "12345" },
    { "key": "queryId", "value": "test-001" }
  ],
  "item": [
    {
      "name": "Search (direct search-ms, synchronous)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{HOST_IP}}:{{VS_HOST_PORT}}/query",
          "protocol": "http",
          "host": ["{{HOST_IP}}"],
          "port": "{{VS_HOST_PORT}}",
          "path": ["query"]
        },
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"queryId\": \"{{queryId}}\",\n    \"query\": \"person wearing a blue shirt\",\n    \"tags\": [\"entrance\", \"aisle-3\"],\n    \"timeFilter\": {\n      \"start\": \"2026-06-25T10:00:00\",\n      \"end\": \"2026-06-25T10:30:00\"\n    }\n  }\n]"
        },
        "description": "POST a JSON ARRAY of query objects to search-ms.\n\nFields:\n- queryId (required; alias query_id)\n- query (required) natural-language text\n- tags (optional) multi-tag, array or comma string; subset/OR match (kept if it matches ANY tag)\n- timeFilter (optional; alias time_filter) start/end ISO 8601 local-tz strings, filters on created_at\n\nReturns results synchronously."
      }
    },
    {
      "name": "Search - tags only (no time filter)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{HOST_IP}}:{{VS_HOST_PORT}}/query",
          "protocol": "http",
          "host": ["{{HOST_IP}}"],
          "port": "{{VS_HOST_PORT}}",
          "path": ["query"]
        },
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"queryId\": \"tags-only-001\",\n    \"query\": \"person with a backpack\",\n    \"tags\": \"entrance,aisle-3\"\n  }\n]"
        },
        "description": "Multi-tag as a comma-separated string. No timeFilter -> falls back to NLP time parsing from the query text (none here, so no time constraint)."
      }
    },
    {
      "name": "Search - time window only (no tags)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{HOST_IP}}:{{VS_HOST_PORT}}/query",
          "protocol": "http",
          "host": ["{{HOST_IP}}"],
          "port": "{{VS_HOST_PORT}}",
          "path": ["query"]
        },
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"queryId\": \"time-only-001\",\n    \"query\": \"person running\",\n    \"timeFilter\": {\n      \"start\": \"2026-06-25T00:00:00\",\n      \"end\": \"2026-06-25T23:59:59\"\n    }\n  }\n]"
        },
        "description": "Absolute start/end window only. Filters frames on created_at between start and end (ISO 8601, local timezone)."
      }
    },
    {
      "name": "Health (search-ms)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://{{HOST_IP}}:{{VS_HOST_PORT}}/health",
          "protocol": "http",
          "host": ["{{HOST_IP}}"],
          "port": "{{VS_HOST_PORT}}",
          "path": ["health"]
        },
        "description": "Quick liveness check for the search microservice."
      }
    },
    {
      "name": "Manager - create search query (async)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://{{HOST_IP}}:{{APP_HOST_PORT}}/manager/search/query",
          "protocol": "http",
          "host": ["{{HOST_IP}}"],
          "port": "{{APP_HOST_PORT}}",
          "path": ["manager", "search", "query"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"person wearing a blue shirt\",\n  \"tags\": [\"entrance\", \"aisle-3\"],\n  \"timeFilter\": {\n    \"start\": \"2026-06-25T10:00:00\",\n    \"end\": \"2026-06-25T10:30:00\"\n  }\n}"
        },
        "description": "Production async flow via the Pipeline Manager (nginx /manager prefix). Returns a queryId; then poll the GET request below."
      }
    },
    {
      "name": "Manager - poll search results",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://{{HOST_IP}}:{{APP_HOST_PORT}}/manager/search/{{queryId}}",
          "protocol": "http",
          "host": ["{{HOST_IP}}"],
          "port": "{{APP_HOST_PORT}}",
          "path": ["manager", "search", "{{queryId}}"]
        },
        "description": "Poll for results of a previously created query. Set the queryId collection variable to the id returned by the create request."
      }
    }
  ]
}
