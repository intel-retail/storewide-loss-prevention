# Secrets — ignore everything except the two scaffold scripts
scenescape/secrets/*
!scenescape/secrets/generate_secrets.sh
!scenescape/secrets/openssl.cnf
docker/.env
docker/.env.bak
scenescape/dlstreamer-pipeline-server/config.json
requirement.txt
application.log
.log_collector.pid
region_events.json
scenescape/sample_data/store-wide-loss-prevention.*

# Python
__pycache__/

# Download models — ignore everything except the scripts and vendored export tools
download_models/*
!download_models/model_download.sh
!download_models/download_models.sh
!download_models/download_sample_video.sh
# Vendored OVMS export tools — committed so a clean checkout never needs to
# fetch them from GitHub raw (which rate-limits, causing curl exit 22).
!download_models/export_model.py
!download_models/export_requirements.txt

# Downloaded models
models/
