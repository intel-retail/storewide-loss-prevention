# Store-wide Loss Prevention environment variables
# Copy to .env and adjust values as needed.

# ---- Host ----
HOST_IP=

# ---- Proxy ----
http_proxy=
https_proxy=
no_proxy=localhost,127.0.0.1

# ---- Store ----
STORE_NAME=retail_store_1
STORE_ID=store_001

# ---- MQTT (SceneScape broker) ----
MQTT_HOST=broker.scenescape.intel.com
MQTT_PORT=1883

# ---- SeaweedFS ----
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080

# ---- External Services ----
BEHAVIORAL_ANALYSIS_URL=http://behavioral-analysis-service:8090
ALERT_SERVICE_URL=http://alert-service:8092

# ---- LP Service ----
LP_SERVICE_PORT=8082
LOG_LEVEL=INFO

# ---- SceneScape API (zone auto-discovery) ----
SCENESCAPE_API_USER=admin
SCENESCAPE_API_PASSWORD=
