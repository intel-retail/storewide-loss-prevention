# Storewide Loss Prevention - Environment Variables
#
# This file is AUTO-GENERATED by init.sh from configs/zone_config.json.
# Do not edit directly — update zone_config.json and re-run: make init
#
# Usage:  make init   (or ../scenescape/scripts/init.sh <app-dir>)

# ---- Secrets (auto-generated) ----
SECRETSDIR=<auto-generated>
SUPASS=<auto-generated>
DATABASE_PASSWORD=<auto-generated>
CONTROLLER_AUTH=<auto-generated>
UID=1000
GID=1000

# ---- All values below are sourced from configs/zone_config.json ----

# Scene
SCENE_NAME=<from zone_config.json>
CAMERA_NAME=<from zone_config.json cameras[0].name>
CAMERA_NAME_2=<from zone_config.json cameras[1].name>
SCENE_ZIP=<from zone_config.json>
VIDEO_FILE=<from zone_config.json cameras[0].video>
VIDEO_FILE_2=<from zone_config.json cameras[1].video>

# DLStreamer pipeline config (generated per camera by init.sh)
PIPELINE_CONFIG=<auto-generated>
PIPELINE_CONFIG_2=<auto-generated>

# Controller configs (from app configs/ directory)
TRACKER_CONFIG=<auto-generated>
REID_CONFIG=<auto-generated>

# OpenVINO Models
MODELS=<from zone_config.json>
MODEL_PRECISION=<from zone_config.json>

# SceneScape images
SCENESCAPE_REGISTRY=<from zone_config.json scenescape.registry>
SCENESCAPE_VERSION=<from zone_config.json scenescape.version>
SCENESCAPE_CONTROLLER_IMAGE=<from zone_config.json scenescape.controller_image>
SCENESCAPE_MANAGER_IMAGE=<from zone_config.json scenescape.manager_image>
DLSTREAMER_VERSION=<from zone_config.json scenescape.dlstreamer_version>

# Store
STORE_NAME=<from zone_config.json store.name>
STORE_ID=<from zone_config.json store.id>

# Services
LP_SERVICE_PORT=<from zone_config.json services.lp_service_port>
LOG_LEVEL=<from zone_config.json services.log_level>

# SeaweedFS
SEAWEEDFS_S3_PORT=<from zone_config.json services.seaweedfs_s3_port>
SEAWEEDFS_MASTER_PORT=<from zone_config.json services.seaweedfs_master_port>
SEAWEEDFS_VOLUME_PORT=<from zone_config.json services.seaweedfs_volume_port>

# SceneScape API
SCENESCAPE_API_USER=<from zone_config.json scenescape.api_user>
SCENESCAPE_API_PASSWORD=<auto-generated>
